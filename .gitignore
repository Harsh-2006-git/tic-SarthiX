**/.env
**/.env.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
**/*.log

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Python
__pycache__/
venv/
.venv/
*.py[cod]
*$py.class
**/venv/
**/.venv/
**/__pycache__/

# Project Specific
uploads/
**/uploads/
AI_Core/uploads/
*.pem
Backend/ca.pem

# OS related
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
